generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SeoEntityType {
  POST
  CATEGORY
  AUTHOR
  PAGE
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  role           UserRole @default(EDITOR)
  displayName    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Author {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  bio            String?
  avatarMediaId  String?
  avatarMedia    Media?      @relation(fields: [avatarMediaId], references: [id])
  posts          Post[]
  seoMetadata    SeoMetadata?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Category {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  description    String?
  posts          Post[]
  seoMetadata    SeoMetadata?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Tag {
  id             String      @id @default(cuid())
  name           String
  slug           String      @unique
  postTags       PostTag[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Media {
  id             String      @id @default(cuid())
  url            String
  altText        String?
  caption        String?
  mimeType       String?
  source         String      @default("external")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  posts          Post[]      @relation("CoverMedia")
  authorAvatars  Author[]
}

model Post {
  id                 String       @id @default(cuid())
  title              String
  slug               String       @unique
  excerpt            String?
  contentMarkdown    String
  contentJson        Json?
  status             PostStatus   @default(DRAFT)
  publishedAt        DateTime?
  readingTimeMinutes Int?
  authorId           String
  author             Author       @relation(fields: [authorId], references: [id])
  categoryId         String?
  category           Category?    @relation(fields: [categoryId], references: [id])
  coverImageId       String?
  coverImage         Media?       @relation("CoverMedia", fields: [coverImageId], references: [id])
  seoMetadata        SeoMetadata?
  postTags           PostTag[]
  relatedFrom        PostRelation[] @relation("SourcePost")
  relatedTo          PostRelation[] @relation("TargetPost")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
}

model PostTag {
  postId    String
  tagId     String
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model PostRelation {
  sourcePostId String
  targetPostId String
  sourcePost   Post @relation("SourcePost", fields: [sourcePostId], references: [id], onDelete: Cascade)
  targetPost   Post @relation("TargetPost", fields: [targetPostId], references: [id], onDelete: Cascade)

  @@id([sourcePostId, targetPostId])
}

model SeoMetadata {
  id               String         @id @default(cuid())
  entityType       SeoEntityType
  title            String?
  description      String?
  canonicalUrl     String?
  noIndex          Boolean        @default(false)
  openGraphImageId String?
  openGraphImage   Media?         @relation(fields: [openGraphImageId], references: [id])
  postId           String?        @unique
  post             Post?          @relation(fields: [postId], references: [id], onDelete: Cascade)
  categoryId       String?        @unique
  category         Category?      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId         String?        @unique
  author           Author?        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  pageKey          String?        @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([entityType])
}
